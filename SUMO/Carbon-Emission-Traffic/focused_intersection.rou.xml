<?xml version="1.0" encoding="UTF-8"?>
<!--
    Focused route file for junction 238 (CARLA TLs 70-73).
    All flows sorted by begin time (SUMO requirement for incremental loading).
-->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- ================================================================
         Vehicle types
         ================================================================ -->
    <vType id="small_car"   vClass="passenger" length="4.5" maxSpeed="33" accel="2.6" decel="4.5" color="0.75,0.75,0.75"/>
    <vType id="medium_van"  vClass="passenger" length="5.5" maxSpeed="28" accel="2.0" decel="4.0" color="0.2,0.4,0.9"/>
    <vType id="large_truck" vClass="truck"     length="8.0" maxSpeed="22" accel="1.5" decel="3.5" color="0.6,0.3,0.1"/>
    <vType id="large_bus"   vClass="truck"     length="9.0" maxSpeed="20" accel="1.2" decel="3.5" color="1.0,0.8,0.0"/>

    <!-- ================================================================
         Flows — sorted by begin time (required by SUMO).
         from/to pairs let SUMO compute routes per vehicle class.

         Approach edges into junction 238:
           24  = east    -23 = west    -69 = north    -4 = south

         Destination edges past junction 238:
           3  = past south exit     30  = past east exit
           22 = past west exit      68  = past north exit
         ================================================================ -->

    <flow id="fe_tk_n"  type="large_truck" from="24"  to="68" begin="0"   end="3600" period="120"/>
    <flow id="fs_tk_w"  type="large_truck" from="-4"  to="22" begin="3"   end="3600" period="120"/>
    <flow id="fw_tk_s"  type="large_truck" from="-23" to="3"  begin="5"   end="3600" period="120"/>
    <flow id="fn_tk_e"  type="large_truck" from="-69" to="30" begin="8"   end="3600" period="120"/>
    <flow id="fe_bs_s"  type="large_bus"   from="24"  to="3"  begin="10"  end="3600" period="120"/>
    <flow id="fs_bs_e"  type="large_bus"   from="-4"  to="30" begin="13"  end="3600" period="120"/>
    <flow id="fw_bs_n"  type="large_bus"   from="-23" to="68" begin="15"  end="3600" period="120"/>
    <flow id="fn_bs_w"  type="large_bus"   from="-69" to="22" begin="18"  end="3600" period="120"/>
    <flow id="fe_md_s"  type="medium_van"  from="24"  to="3"  begin="20"  end="3600" period="120"/>
    <flow id="fw_md_e"  type="medium_van"  from="-23" to="30" begin="23"  end="3600" period="120"/>
    <flow id="fn_md_e"  type="medium_van"  from="-69" to="30" begin="25"  end="3600" period="120"/>
    <flow id="fs_md_e"  type="medium_van"  from="-4"  to="30" begin="28"  end="3600" period="120"/>
    <flow id="fe_sm_s"  type="small_car"   from="24"  to="3"  begin="30"  end="3600" period="150"/>
    <flow id="fs_sm_e"  type="small_car"   from="-4"  to="30" begin="35"  end="3600" period="150"/>
    <flow id="fw_sm_e"  type="small_car"   from="-23" to="30" begin="40"  end="3600" period="150"/>
    <flow id="fn_sm_e"  type="small_car"   from="-69" to="30" begin="45"  end="3600" period="150"/>
    <flow id="fs_sm_n"  type="small_car"   from="-4"  to="68" begin="50"  end="3600" period="150"/>
    <flow id="fn_sm_w"  type="small_car"   from="-69" to="22" begin="55"  end="3600" period="150"/>
    <flow id="fe_sm_n"  type="small_car"   from="24"  to="68" begin="60"  end="3600" period="150"/>
    <flow id="fs_sm_w"  type="small_car"   from="-4"  to="22" begin="65"  end="3600" period="150"/>
    <flow id="fw_sm_s"  type="small_car"   from="-23" to="3"  begin="70"  end="3600" period="150"/>
    <flow id="fn_sm_s"  type="small_car"   from="-69" to="3"  begin="75"  end="3600" period="150"/>
    <flow id="fw_md_s"  type="medium_van"  from="-23" to="3"  begin="80"  end="3600" period="120"/>
    <flow id="fn_md_w"  type="medium_van"  from="-69" to="22" begin="82"  end="3600" period="120"/>

</routes>
