{
    "name": "Senior Project (SUMO/CARLA)",
    "dockerFile": "Dockerfile",
    "context": "..",
    "workspaceFolder": "/workspaces/Senior-Project",
    "appPort": [8000, 2000],
    "forwardPorts": [8000, 2000],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.isort",
                "ms-python.black-formatter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3"
            }
        }
    },
    "containerEnv": {
        "SUMO_HOME": "/usr/share/sumo",
        "PYTHONPATH": "/usr/share/sumo/tools"
    },
    "remoteUser": "root"
}